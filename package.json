{
  "name": "gym-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22.13 <25"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint:src",
    "lint:src": "eslint . && depcruise apps packages --config .dependency-cruiser.cjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dependency-cruiser": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "next": "catalog:",
    "turbo": "2.9.18",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
