# Supabase — shared across every tenant (ADR-0008: the URL + publishable key are
# identical for all gyms; the Supabase project is the SAME one admin uses). Never
# push a tenant secret into NEXT_PUBLIC_*.
#
# Copy to `.env.local` IN THIS DIRECTORY (apps/client/.env.local, gitignored).
# Next loads .env from the app directory, NOT the repo root. The publishable
# (anon) key is safe to expose to the browser. Phase 2 only INSTANTIATES the
# client factory against these (no query), so any well-formed URL + key suffices
# until the real values are provisioned (the Vercel HITL slice).

NEXT_PUBLIC_SUPABASE_URL=https://hjppxawglmukfvsgmcog.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Cloudflare Turnstile — the captcha guarding the contact-form intake (slice #53). The public sitekey is
# rendered into the widget; the secret verifies the token server-side. Both default (in code) to
# Cloudflare's documented ALWAYS-PASS test pair, so dev + tests work with these left blank. Production
# keys are provisioned by the owner as a post-queue step.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
